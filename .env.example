# ── Vercel Environment Variables ──────────────────────────────────────────────
# Set these in: Vercel Dashboard → Your Project → Settings → Environment Variables

# Your n8n carrier search webhook URL
N8N_SEARCH_URL=https://n8n.turbofreightllc.com/webhook/carrier-search

# Your FMCSA API web key (request free at: https://mobile.fmcsa.dot.gov/QCDevsite/)
FMCSA_KEY=your_fmcsa_web_key_here

# ── Supabase (add directly in index.html) ─────────────────────────────────────
# These go in index.html as SUPABASE_URL and SUPABASE_ANON_KEY constants.
# The anon key is safe to expose in frontend code — security is enforced by RLS policies.
# Get these from: Supabase Dashboard → Your Project → Settings → API

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
